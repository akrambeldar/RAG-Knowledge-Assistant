# RAG Pipeline Explorer
Run each cell one at a time. This lets you inspect every stage of the pipeline before deploying.
## Cell 1 — Load environment variables
from dotenv import load_dotenv
import os

load_dotenv('../.env')  # loads from root .env file

print('OPENAI_API_KEY loaded:', bool(os.getenv('OPENAI_API_KEY')))
print('ANTHROPIC_API_KEY loaded:', bool(os.getenv('ANTHROPIC_API_KEY')))
## Cell 2 — Load and inspect your documents
from langchain_community.document_loaders import PyPDFLoader, DirectoryLoader, TextLoader

# Load all docs from the docs/ folder
loader = DirectoryLoader('../docs', glob='**/*.txt', loader_cls=TextLoader)
raw_docs = loader.load()

print(f'Total documents loaded: {len(raw_docs)}')
print('---')
for i, doc in enumerate(raw_docs):
    print(f'Doc {i+1}: {doc.metadata.get("source", "unknown")} | {len(doc.page_content)} chars')
    print(f'Preview: {doc.page_content[:200]}...')
    print()
## Cell 3 — Chunk the documents and inspect chunk sizes
from langchain.text_splitter import RecursiveCharacterTextSplitter

splitter = RecursiveCharacterTextSplitter(
    chunk_size=512,
    chunk_overlap=64,
    separators=['\n\n', '\n', '. ', ' ']
)

chunks = splitter.split_documents(raw_docs)

print(f'Total chunks created: {len(chunks)}')
print(f'Average chunk size: {sum(len(c.page_content) for c in chunks) // len(chunks)} chars')
print(f'Smallest chunk: {min(len(c.page_content) for c in chunks)} chars')
print(f'Largest chunk: {max(len(c.page_content) for c in chunks)} chars')
print('\n--- Sample chunk ---')
print(chunks[0].page_content)
print('\nMetadata:', chunks[0].metadata)
## Cell 4 — Generate embeddings and inspect vectors
from langchain_openai import OpenAIEmbeddings

embeddings = OpenAIEmbeddings(model='text-embedding-ada-002')

# Embed a single test sentence
test_sentence = 'What is retrieval augmented generation?'
vector = embeddings.embed_query(test_sentence)

print(f'Embedding dimensions: {len(vector)}')
print(f'First 10 values: {[round(v, 4) for v in vector[:10]]}')
print(f'\nThis 1536-dimension vector is what gets stored in your vector database.')
## Cell 5 — Build the Chroma vector store from your chunks
from langchain_community.vectorstores import Chroma

print('Embedding and indexing chunks... (this may take 30-60 seconds)')

vectorstore = Chroma.from_documents(
    chunks,
    embeddings,
    persist_directory='../chroma_db'
)

print(f'Vector store created with {vectorstore._collection.count()} vectors')
print('Saved to chroma_db/ folder')
## Cell 6 — Test retrieval: what chunks get returned for a query?
retriever = vectorstore.as_retriever(search_kwargs={'k': 3})

test_query = 'What is this document about?'  # change this to test different queries

retrieved_docs = retriever.invoke(test_query)

print(f'Query: "{test_query}"')
print(f'Retrieved {len(retrieved_docs)} chunks:\n')

for i, doc in enumerate(retrieved_docs):
    print(f'--- Chunk {i+1} ---')
    print(f'Source: {doc.metadata.get("source", "unknown")}')
    print(f'Content: {doc.page_content[:300]}...')
    print()
## Cell 7 — Test similarity scores (which chunk is most relevant?)
# similarity_search_with_score returns (doc, score) tuples
# Lower score = more similar in Chroma (it uses L2 distance)

results_with_scores = vectorstore.similarity_search_with_score(test_query, k=5)

print(f'Query: "{test_query}"\n')
print(f'{"Rank":<6} {"Score":<10} {"Preview"}')
print('-' * 70)

for rank, (doc, score) in enumerate(results_with_scores, 1):
    preview = doc.page_content[:80].replace('\n', ' ')
    print(f'{rank:<6} {score:<10.4f} {preview}...')
## Cell 8 — Run the full RAG chain end-to-end
from langchain_openai import ChatOpenAI
from langchain.prompts import ChatPromptTemplate
from langchain_core.runnables import RunnablePassthrough
from langchain_core.output_parsers import StrOutputParser

PROMPT = ChatPromptTemplate.from_template("""
You are a precise knowledge assistant. Answer using ONLY the context below.
If the answer is not in the context, say "I don't have information on that."

Context:
{context}

Question: {question}

Answer:""")

llm = ChatOpenAI(model='gpt-4o-mini', temperature=0)

def format_docs(docs):
    return '\n\n'.join(
        f'[Source: {d.metadata.get("source", "?")}]\n{d.page_content}'
        for d in docs
    )

rag_chain = (
    {'context': retriever | format_docs, 'question': RunnablePassthrough()}
    | PROMPT
    | llm
    | StrOutputParser()
)

question = 'What is this document about?'  # change this to test
answer = rag_chain.invoke(question)

print(f'Q: {question}')
print(f'A: {answer}')
## Cell 9 — Test multiple questions in a batch
# Edit these questions to match your actual documents
test_questions = [
    'What is the main topic of the document?',
    'What are the key points mentioned?',
    'Who is the author or source?',
    'What year or time period does this cover?',
    'Something unrelated to test hallucination'
]

print('Running batch evaluation...\n')
print(f'{"Question":<50} {"Answer"}')
print('-' * 100)

for q in test_questions:
    a = rag_chain.invoke(q)
    print(f'{q:<50} {a[:80]}...' if len(a) > 80 else f'{q:<50} {a}')
    print()
## Cell 10 — Quick RAGAs evaluation (faithfulness + relevancy)
from ragas import evaluate
from ragas.metrics import faithfulness, answer_relevancy
from datasets import Dataset

# Define questions + ground truth answers based on YOUR documents
eval_questions = [
    'What is this document about?',
    'What are the key points mentioned?'
]
ground_truths = [
    'Write the expected answer here based on your document.',
    'Write the expected answer here based on your document.'
]

# Generate answers and retrieve contexts
answers = [rag_chain.invoke(q) for q in eval_questions]
contexts = [[d.page_content for d in retriever.invoke(q)] for q in eval_questions]

eval_dataset = Dataset.from_dict({
    'question': eval_questions,
    'answer': answers,
    'contexts': contexts,
    'ground_truth': ground_truths
})

result = evaluate(eval_dataset, metrics=[faithfulness, answer_relevancy])
print('RAGAs Evaluation Results:')
print(f'Faithfulness:      {result["faithfulness"]:.2f}  (target: > 0.85)')
print(f'Answer Relevancy:  {result["answer_relevancy"]:.2f}  (target: > 0.80)')
